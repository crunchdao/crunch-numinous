# Numinous Gateway — API Keys
# Run `crunch-numinous gateway configure` to set up interactively
# Or copy this file to gateway/.env and fill in your actual API keys

# Chutes AI (https://chutes.ai/app)
CHUTES_API_KEY=

# Desearch AI (https://desearch.ai)
DESEARCH_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Perplexity (https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=

# Vericore (https://vericore.ai)
VERICORE_API_KEY=

# OpenRouter (https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=